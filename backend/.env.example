# ─── Server ───────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
FRONTEND_ORIGIN=http://localhost:3000

# ─── 0G Chain (Newton Testnet) ────────────────────────────────────────────────
# RPC endpoint for the 0G EVM-compatible chain
OG_CHAIN_RPC=https://evmrpc-testnet.0g.ai
# Chain ID for 0G Newton Testnet
OG_CHAIN_ID=16600
# Private key for the custodial hot wallet (no 0x prefix required)
OG_HOT_WALLET_PRIVATE_KEY=your_private_key_here
# Optional: A read-only address used for balance queries without exposing key
OG_HOT_WALLET_ADDRESS=0xYourHotWalletAddress

# ─── 0G Storage ───────────────────────────────────────────────────────────────
# Indexer RPC for the 0G Storage network (testnet)
OG_STORAGE_INDEXER_RPC=https://indexer-storage-testnet-standard.0g.ai
# Flow contract address on 0G Newton Testnet
OG_STORAGE_FLOW_CONTRACT=0xbD2C3F0E65eDF5582141C35969d66e205f5cc79

# ─── 0G Compute ───────────────────────────────────────────────────────────────
# Serving contract address for the 0G Compute / Serving network (testnet)
OG_COMPUTE_SERVING_CONTRACT=0x0000000000000000000000000000000000000000
# Ledger contract address for compute billing
OG_COMPUTE_LEDGER_CONTRACT=0x0000000000000000000000000000000000000000

# ─── Bridge Watcher ───────────────────────────────────────────────────────────
# LayerZero endpoint / bridge contract to watch for incoming deposits
BRIDGE_CONTRACT_ADDRESS=0xYourBridgeContractAddress
# Block interval (ms) for polling the bridge contract
BRIDGE_POLL_INTERVAL_MS=6000

# ─── Payment Gateways ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
PAYSTACK_SECRET_KEY=sk_test_...
PAYSTACK_WEBHOOK_SECRET=your_paystack_webhook_secret

# ─── Security ─────────────────────────────────────────────────────────────────
API_SECRET=a_long_random_secret_for_internal_routes
